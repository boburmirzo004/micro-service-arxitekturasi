# .env konfiguratsiya
# bu faylni .env ga nusxalang: cp .env.example .env
# keyin IP larni ozgartirasiz

HOST=0.0.0.0
PORT=8000

# backend servislar, real serverda IP larni yozing
BACKEND_SERVICES=["http://192.168.1.10:8001","http://192.168.1.11:8002","http://192.168.1.12:8003"]

# vaznlar (weighted round robin uchun)
SERVICE_WEIGHTS={"http://192.168.1.10:8001": 3, "http://192.168.1.11:8002": 2, "http://192.168.1.12:8003": 1}

# algoritm: round_robin, random, least_connections, weighted_round_robin
LB_ALGORITHM=round_robin

HEALTH_CHECK_INTERVAL=5


